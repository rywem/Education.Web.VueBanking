{
  // Config for your actual application code (everything under src/).
  // @vue/tsconfig provides the strict base — equivalent to turning on every
  // analyzer warning + TreatWarningsAsErrors in a .csproj. Don't loosen it.
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    // Path alias: "@/foo" -> "src/foo". This is the TS/Vite equivalent of a
    // rooted namespace import. Vite resolves it at build time (configured in
    // vite.config.ts); this block is what makes the *editor* understand it.
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "src/**/*.vue", "env.d.ts"],
  "exclude": ["src/**/__tests__/*"]
}
